{
  "name": "ai-shotlive-director",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "build:electron-main": "tsc -p electron/tsconfig.json",
    "start": "node server/dist/index.js",
    "start:local": "DB_TYPE=sqlite NODE_ENV=production node server/dist/index.js",
    "dev:local": "DB_TYPE=sqlite concurrently \"npm run dev:client\" \"DB_TYPE=sqlite tsx watch server/src/index.ts\"",
    "build:local": "bash scripts/build-local.sh",
    "build:electron": "bash scripts/build-electron.sh",
    "build:electron:mac": "bash scripts/build-electron.sh mac",
    "build:electron:win": "bash scripts/build-electron.sh win",
    "preview": "vite preview",
    "migrate:episode-ids": "tsx server/src/scripts/migrateEpisodeIds.ts",
    "migrate:episode-paths": "tsx server/src/scripts/migrateToEpisodePaths.ts"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/electron": "^7.11.0",
    "@sentry/node": "^10.48.0",
    "@sentry/react": "^10.48.0",
    "@sentry/vite-plugin": "^5.2.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "framer-motion": "^12.34.3",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.554.0",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.12.0",
    "re-resizable": "^6.11.2",
    "react": "^19.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^2.1.7",
    "tailwind-merge": "^3.5.0",
    "use-immer": "^0.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.4",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
